page {
  min-height: 100vh;
  color: #263238;
  background: #fff8ec;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  font: inherit;
  line-height: 1;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ffb12f, #ff8a1f);
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(255, 138, 31, 0.22);
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border: 2rpx solid #dbeafe;
  border-radius: 14rpx;
  color: #1e88e5;
  background: #eff7ff;
  font-weight: 700;
}

.muted {
  color: #7b8794;
}
