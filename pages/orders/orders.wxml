<view class="page orders-page">
  <view class="sync-card {{cloudReady ? 'online' : 'offline'}}">
    <view>
      <view class="sync-title">{{cloudReady ? '远程同步已开启' : '本地演示模式'}}</view>
      <view class="sync-desc">
        {{cloudReady ? '家人下单后，此页会自动刷新。' : '填入云开发环境 ID 后，A/B 手机即可同步订单。'}}
      </view>
    </view>
    <view class="sync-dot"></view>
  </view>

  <view class="section-row">
    <view class="section-title">最近订单</view>
    <button class="secondary-btn menu-btn" bindtap="goMenu">点菜</button>
  </view>

  <block wx:if="{{loading}}">
    <view class="empty">正在读取订单...</view>
  </block>

  <block wx:elif="{{orders.length}}">
    <block wx:for="{{orders}}" wx:key="_id">
      <view class="order-card">
        <view class="order-head">
          <view>
            <view class="order-title">{{item.totalItems}} 道菜</view>
            <view class="order-time">{{item.createdAtText}}</view>
          </view>
          <text class="status">{{item.status}}</text>
        </view>

        <view class="dish-line">
          <block wx:for="{{item.dishes}}" wx:key="id" wx:for-item="dish">
            <text>{{dish.name}}</text>
          </block>
        </view>

        <view class="ingredient-summary">
          <block wx:for="{{item.ingredients}}" wx:key="name" wx:for-item="ingredient">
            <text class="{{ingredient.ready ? 'ready' : 'missing'}}">
              {{ingredient.ready ? '✓' : '!'}} {{ingredient.name}}
            </text>
          </block>
        </view>
      </view>
    </block>
  </block>

  <block wx:else>
    <view class="empty">
      <view class="empty-title">暂无订单</view>
      <view class="empty-desc">提交第一单后，会在这里显示并同步给家人。</view>
    </view>
  </block>
</view>
